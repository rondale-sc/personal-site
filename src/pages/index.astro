---
import Base from '../layouts/Base.astro';
---
<Base title="Jonathan Jackson" description="Staff Software Engineer at LinkedIn. Amateur radio operator and builder of things.">
  <div class="home-hero">
    <div class="home-content">
      <h1>Jonathan Jackson</h1>
      <p>
        Staff Software Engineer at LinkedIn with nearly two decades of experience.
        Background spans consultancies, fintech, and open-source—including
        co-hosting <a href="https://emberweekend.com">Ember Weekend</a>, a weekly
        Ember.js podcast, from 2015 to 2020.
      </p>
      <p>
        Licensed amateur radio operator and builder of things—most recently a
        <a href="/projects/6502-breadboard-computer">working 6502 breadboard computer</a>.
      </p>
      <ul class="home-links">
        <li><a href="/projects">Projects</a></li>
        <li><a href="/interests">Interests</a></li>
        <li><a href="/resume">Resume</a></li>
        <li><a href="https://github.com/rondale-sc">GitHub</a></li>
        <li><a href="https://www.linkedin.com/in/jonathan-jackson-a85999133/">LinkedIn</a></li>
      </ul>
    </div>
    <div class="hero-photo">
      <img src="/jonathan.jpg" alt="Jonathan Jackson" />
    </div>
  </div>
</Base>

<style>
  .home-hero {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .home-content {
    flex: 1;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  p {
    margin: 0 0 1rem;
  }

  .home-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    font-size: 0.95rem;
  }

  .hero-photo {
    width: 260px;
    height: 340px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Show middle portion: crop ~10% from top, ~30% from bottom */
    object-position: center 25%;
  }

  @media (max-width: 560px) {
    .home-hero {
      flex-direction: column-reverse;
    }

    .hero-photo {
      width: 100%;
      height: 220px;
    }
  }
</style>
