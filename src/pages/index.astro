---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getPostHref, getPostSection } from '../lib/posts';

const experience = [
  { period: '2022 – present', role: 'Staff Software Engineer', company: 'LinkedIn' },
  { period: '2019 – 2022',    role: 'Senior Software Engineer', company: 'Addepar' },
  { period: '2017 – 2019',    role: 'Senior Developer',        company: '201 Created' },
  { period: '2013 – 2016',    role: 'Senior Developer',        company: 'Hashrocket' },
  { period: '2009 – 2013',    role: 'Software Engineer',       company: 'Pro Medical, Inc.' },
];

const all = await getCollection('posts');
const recent = all
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---
<Base title="Jonathan Jackson" description="Staff Software Engineer at LinkedIn. Amateur radio operator and builder of things." ogImage="/og/home.png">
  <div class="home-hero">
    <div class="home-content">
      <h1>Jonathan Jackson</h1>
      <p>
        Staff Software Engineer at LinkedIn with nearly two decades of experience.
        Background spans consultancies, fintech, and open-source—including
        co-hosting <a href="https://emberweekend.com">Ember Weekend</a>, a weekly
        Ember.js podcast, from 2015 to 2020.
      </p>
      <p>
        Licensed amateur radio operator and builder of things—most recently a
        <a href="/projects/6502-breadboard-computer">working 6502 breadboard computer</a>.
      </p>
    </div>
    <div class="hero-photo">
      <img src="/jonathan.jpg" alt="Jonathan Jackson" />
    </div>
  </div>

  <section class="experience">
    <h2 class="section-label">Experience</h2>
    <ol class="timeline">
      {experience.map(job => (
        <li>
          <span class="timeline-period">{job.period}</span>
          <span class="timeline-body">
            <strong class="timeline-role">{job.role}</strong>
            <span class="timeline-company">{job.company}</span>
          </span>
        </li>
      ))}
    </ol>
  </section>

  {recent.length > 0 && (
    <section class="recent">
      <h2 class="section-label">Recent</h2>
      <ul class="recent-list">
        {recent.map(post => (
          <li class="recent-entry">
            <a href={getPostHref(post)} class="recent-link">
              <span class="type-badge">{getPostSection(post)}</span>
              <span class="recent-title">{post.data.title}</span>
              <time class="recent-date" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  .home-hero {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .home-content {
    flex: 1;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  p {
    margin: 0 0 1rem;
  }

  .hero-photo {
    width: 260px;
    height: 340px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px var(--shadow);
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  /* Experience */
  .experience {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .timeline li {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
  }

  .timeline-period {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    width: 120px;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .timeline-body {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.5rem;
  }

  .timeline-role {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
  }

  .timeline-company {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  /* Recent posts */
  .recent {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .recent-entry {
    border-bottom: 1px solid var(--border);
  }

  .recent-entry:first-child {
    border-top: 1px solid var(--border);
  }

  .recent-link {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.625rem 0;
    text-decoration: none;
    color: inherit;
  }

  .recent-link:hover .recent-title { color: var(--accent); }

  .type-badge {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15em 0.45em;
    border-radius: 3px;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--accent) 12%, var(--surface));
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .recent-title {
    flex: 1;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text);
  }

  .recent-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 560px) {
    .home-hero {
      flex-direction: column-reverse;
    }

    .hero-photo {
      width: 100%;
      height: 220px;
    }

    .timeline li {
      flex-direction: column;
      gap: 0.125rem;
    }

    .timeline-period {
      width: auto;
    }

    .recent-link {
      flex-wrap: wrap;
    }

    .recent-date {
      order: -1;
      flex-basis: 100%;
    }
  }
</style>
