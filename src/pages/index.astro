---
import Base from '../layouts/Base.astro';

const experience = [
  { period: '2022 – present', role: 'Staff Software Engineer', company: 'LinkedIn' },
  { period: '2019 – 2022',    role: 'Software Engineer',       company: 'Addepar' },
  { period: '2017 – 2019',    role: 'Senior Developer',        company: '201 Created' },
  { period: '2013 – 2016',    role: 'Senior Developer',        company: 'Hashrocket' },
  { period: '2009 – 2013',    role: 'Software Engineer',       company: 'Pro Medical, Inc.' },
];
---
<Base title="Jonathan Jackson" description="Staff Software Engineer at LinkedIn. Amateur radio operator and builder of things.">
  <div class="home-hero">
    <div class="home-content">
      <h1>Jonathan Jackson</h1>
      <p>
        Staff Software Engineer at LinkedIn with nearly two decades of experience.
        Background spans consultancies, fintech, and open-source—including
        co-hosting <a href="https://emberweekend.com">Ember Weekend</a>, a weekly
        Ember.js podcast, from 2015 to 2020.
      </p>
      <p>
        Licensed amateur radio operator and builder of things—most recently a
        <a href="/projects/6502-breadboard-computer">working 6502 breadboard computer</a>.
      </p>
    </div>
    <div class="hero-photo">
      <img src="/jonathan.jpg" alt="Jonathan Jackson" />
    </div>
  </div>

  <section class="experience">
    <h2 class="section-label">Experience</h2>
    <ol class="timeline">
      {experience.map(job => (
        <li>
          <span class="timeline-period">{job.period}</span>
          <span class="timeline-body">
            <strong class="timeline-role">{job.role}</strong>
            <span class="timeline-company">{job.company}</span>
          </span>
        </li>
      ))}
    </ol>
  </section>
</Base>

<style>
  .home-hero {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .home-content {
    flex: 1;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  p {
    margin: 0 0 1rem;
  }

  .hero-photo {
    width: 260px;
    height: 340px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px var(--shadow);
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  /* Experience */
  .experience {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .timeline li {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
  }

  .timeline-period {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    width: 120px;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .timeline-body {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.5rem;
  }

  .timeline-role {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
  }

  .timeline-company {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  @media (max-width: 560px) {
    .home-hero {
      flex-direction: column-reverse;
    }

    .hero-photo {
      width: 100%;
      height: 220px;
    }

    .timeline li {
      flex-direction: column;
      gap: 0.125rem;
    }

    .timeline-period {
      width: auto;
    }
  }
</style>
