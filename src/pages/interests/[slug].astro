---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getPostHref } from '../../lib/posts';

export async function getStaticPaths() {
  const interests = await getCollection('interests');
  return interests.map(interest => ({
    params: { slug: interest.id },
    props: { interest },
  }));
}

const { interest } = Astro.props;

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.data.interest === interest.id && !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title={interest.data.title} description={interest.data.description}>
  <h1>{interest.data.title}</h1>
  {interest.data.description && <p class="section-desc">{interest.data.description}</p>}

  {posts.length === 0 ? (
    <p><em>Nothing here yet.</em></p>
  ) : (
    <ul class="post-list">
      {posts.map(post => (
        <li class="post-row">
          <a href={getPostHref(post)} class="post-link">
            <span class="post-title">{post.data.title}</span>
            <time class="post-date" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>

<style>
  h1 { margin-bottom: 0.25rem; }

  .section-desc {
    margin: 0 0 1.5rem;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-row { border-bottom: 1px solid var(--border); }
  .post-row:first-child { border-top: 1px solid var(--border); }

  .post-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-link:hover .post-title { color: var(--accent); }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
</style>
