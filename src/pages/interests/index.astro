---
import Base from '../../layouts/Base.astro';
import { fetchShelf } from '../../lib/goodreads';
import { getCollection } from 'astro:content';

const [recentBook, dogs, interests, allPosts] = await Promise.all([
  fetchShelf('currently-reading').then(b => b[0] ?? null),
  getCollection('dogs'),
  getCollection('interests'),
  getCollection('posts'),
]);

const penny = dogs.find(d => d.data.name === 'Penny');
const pennyPhoto = penny?.data.photos?.[0] ?? null;

// For each dynamic interest, find the most recent post thumbnail
function interestThumb(slug: string) {
  return allPosts
    .filter(p => p.data.interest === slug && !p.data.draft && p.data.thumbnail)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0]
    ?.data.thumbnail ?? null;
}

const dynamicAreas = interests
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .map(i => ({
    name: i.data.title,
    href: `/interests/${i.id}`,
    description: i.data.description ?? '',
    thumbnail: i.data.thumbnail ?? interestThumb(i.id),
    thumbnailAlt: i.data.title,
  }));

const specialAreas = [
  {
    name: 'Reading',
    href: '/interests/reading',
    description: 'Books from the shelf — philosophy, science, and whatever catches my eye.',
    thumbnail: recentBook?.cover ?? null,
    thumbnailAlt: recentBook ? `${recentBook.title} cover` : 'Reading',
  },
  {
    name: 'Furry Friends',
    href: '/interests/dogs',
    description: 'Dogs past and present. Avid dog park attendee.',
    thumbnail: pennyPhoto,
    thumbnailAlt: 'Penny',
  },
];

const areas = [...dynamicAreas, ...specialAreas];
---
<Base title="Interests" description="Things I'm into.">
  <h1>Interests</h1>
  <ul class="area-list">
    {areas.map(area => (
      <li class="area-card">
        <a href={area.href} class="area-link">
          <div class="area-thumb">
            {area.thumbnail
              ? <img src={area.thumbnail} alt={area.thumbnailAlt} loading="lazy" />
              : <div class="area-thumb-placeholder" aria-hidden="true">
                  <span>{area.name[0]}</span>
                </div>
            }
          </div>
          <div class="area-body">
            <strong class="area-name">{area.name}</strong>
            <p class="area-desc">{area.description}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  h1 { margin-bottom: 1.5rem; }

  .area-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .area-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .area-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 8px var(--shadow);
  }

  .area-link {
    display: flex;
    align-items: stretch;
    text-decoration: none;
    color: inherit;
  }

  .area-thumb {
    width: 100px;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--border);
  }

  .area-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .area-thumb-placeholder {
    width: 100%;
    height: 100%;
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-muted);
    background: color-mix(in srgb, var(--accent) 10%, var(--surface));
  }

  .area-body {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.3rem;
  }

  .area-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent);
  }

  .area-card:hover .area-name { color: var(--accent-hover); }

  .area-desc {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.45;
  }
</style>
