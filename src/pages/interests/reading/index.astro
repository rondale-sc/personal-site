---
import Base from '../../../layouts/Base.astro';
import { fetchShelf } from '../../../lib/goodreads';

const [current, read] = await Promise.all([
  fetchShelf('currently-reading'),
  fetchShelf('read'),
]);

function stars(n: number) {
  if (!n) return '';
  return '★'.repeat(n) + '☆'.repeat(5 - n);
}
---
<Base title="Reading" description="Books I'm reading and have read." ogImage="/og/interests-reading.png">
  <h1>Reading</h1>
  <p class="shelf-intro">
    I recently started tracking my reading on <a href="https://www.goodreads.com/user/show/200941836-jonathan" target="_blank" rel="noopener">Goodreads</a> in mid-2026, so the history here is a work in progress. This page syncs automatically from my shelves on every deploy.
  </p>

  {current.length > 0 && (
    <section class="shelf">
      <h2 class="shelf-label">Currently reading</h2>
      <ul class="book-list">
        {current.map(book => (
          <li class="book-entry">
            <a href={book.link} target="_blank" rel="noopener" class="book-cover-link">
              {book.cover
                ? <img src={book.cover} alt={book.title} class="book-cover" loading="lazy" />
                : <div class="book-cover book-cover-placeholder" />
              }
            </a>
            <div class="book-info">
              <a href={book.link} target="_blank" rel="noopener" class="book-title">{book.title}</a>
              <span class="book-author">{book.author}</span>
              {book.published && <span class="book-meta">{book.published}</span>}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  {read.length > 0 && (
    <section class="shelf">
      <h2 class="shelf-label">Read</h2>
      <ul class="book-list">
        {read.map(book => (
          <li class="book-entry">
            <a href={book.link} target="_blank" rel="noopener" class="book-cover-link">
              {book.cover
                ? <img src={book.cover} alt={book.title} class="book-cover" loading="lazy" />
                : <div class="book-cover book-cover-placeholder" />
              }
            </a>
            <div class="book-info">
              <a href={book.link} target="_blank" rel="noopener" class="book-title">{book.title}</a>
              <span class="book-author">{book.author}</span>
              <span class="book-meta">
                {book.rating > 0 && <span class="book-stars">{stars(book.rating)}</span>}
                {book.published && <span>{book.published}</span>}
              </span>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  {current.length === 0 && read.length === 0 && (
    <p><em>Nothing loaded — check back soon.</em></p>
  )}
</Base>

<style>
  h1 { margin-bottom: 0.25rem; }

  .shelf-intro {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0 0 2rem;
  }

  .shelf {
    margin-bottom: 2.5rem;
  }

  .shelf-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }

  .book-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .book-entry {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--border);
  }

  .book-entry:first-child {
    border-top: 1px solid var(--border);
  }

  .book-cover-link {
    flex-shrink: 0;
  }

  .book-cover {
    width: 52px;
    height: 78px;
    object-fit: cover;
    border-radius: 3px;
    border: 1px solid var(--border);
    box-shadow: 0 1px 3px var(--shadow);
    display: block;
  }

  .book-cover-placeholder {
    background: var(--surface);
  }

  .book-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-top: 0.1rem;
  }

  .book-title {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--text);
    text-decoration: none;
    line-height: 1.3;
  }

  .book-title:hover { color: var(--accent); }

  .book-author {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .book-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .book-stars {
    color: var(--accent);
    letter-spacing: -0.05em;
  }
</style>
