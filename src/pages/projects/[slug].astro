---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getPostSlug } from '../../lib/posts';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.data.project === project.id && !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title={project.data.title} description={project.data.summary}>
  <div class="project-header">
    {project.data.thumbnail && (
      <img src={project.data.thumbnail} alt={project.data.title} class="project-thumb" />
    )}
    <h1>{project.data.title}</h1>
    {project.data.summary && <p class="project-summary">{project.data.summary}</p>}
    <p class="project-meta">
      {project.data.status && <span class="status">{project.data.status}</span>}
      {project.data.tags.length > 0 && <span class="tags">{project.data.tags.join(', ')}</span>}
    </p>
  </div>

  {posts.length === 0 ? (
    <p><em>No updates yet.</em></p>
  ) : (
    <ul class="post-list">
      {posts.map(post => (
        <li class="post-row">
          <a href={`/posts/${getPostSlug(post)}`} class="post-link">
            <span class="post-title">{post.data.title}</span>
            <time class="post-date" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>

<style>
  .project-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .project-thumb {
    width: 120px;
    height: auto;
    display: block;
    margin-bottom: 1rem;
  }

  .project-header h1 { margin: 0 0 0.5rem; }

  .project-summary {
    margin: 0 0 0.75rem;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  .project-meta {
    margin: 0;
    display: flex;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .status { text-transform: capitalize; }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-row {
    border-bottom: 1px solid var(--border);
  }

  .post-row:first-child {
    border-top: 1px solid var(--border);
  }

  .post-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-link:hover .post-title { color: var(--accent); }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
</style>
