---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.data.project === project.id && !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const rendered = await Promise.all(
  posts.map(async p => ({ post: p, Content: (await render(p)).Content }))
);
---
<Base title={project.data.title} description={project.data.summary}>
  <div class="project-header">
    <h1>{project.data.title}</h1>
    {project.data.summary && <p class="project-summary">{project.data.summary}</p>}
    <p class="project-meta">
      {project.data.status && <span class="status">{project.data.status}</span>}
      {project.data.tags.length > 0 && <span class="tags">{project.data.tags.join(', ')}</span>}
    </p>
  </div>

  {rendered.length === 0 ? (
    <p><em>No updates yet.</em></p>
  ) : (
    <div class="post-feed">
      {rendered.map(({ post, Content }) => (
        <article class="post-entry">
          <header class="post-header">
            <h2 class="post-title">{post.data.title}</h2>
            <time class="post-date" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </header>
          <div class="prose">
            <Content />
          </div>
        </article>
      ))}
    </div>
  )}
</Base>

<style>
  .project-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .project-header h1 {
    margin: 0 0 0.5rem;
  }

  .project-summary {
    margin: 0 0 0.75rem;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  .project-meta {
    margin: 0;
    display: flex;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .status {
    text-transform: capitalize;
  }

  .post-feed {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-entry {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-entry:first-child {
    border-top: 1px solid var(--border);
  }

  .post-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--text);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
</style>
